# 服务器真实模型验收需要设置为 1；不验收真实调用时保持 0。
ALLOW_LIVE_MODEL_CALLS=0
SAMPLING_MAX_WORKERS=8
# 未命中特定信息源限流时的兜底值。
SAMPLING_PROVIDER_MAX_WORKERS=1
# 信息源级并发上限。OpenRouter-GPT 和 OpenRouter-Gemini 共享 openrouter 上限；DeepSeek 联网会同时消耗 Brave Search。
SAMPLING_PROVIDER_CONCURRENCY_LIMITS=openrouter=4,deepseek=2,doubao=2,qwen=2,hunyuan=2,openai=2,gemini=2,kimi=2,ernie=2,minimax=2
SAMPLING_REQUEST_TIMEOUT=150
SAMPLING_RETRY_COUNT=1
SQLITE_WAL=1

DATABASE_URL=
REDIS_URL=redis://127.0.0.1:6379/0
TASK_QUEUE_BACKEND=rq
RQ_QUEUE_NAME=geo-audit
RQ_JOB_TIMEOUT=3600

